    "MOVE": {"description": "Data assignment", "aws_equivalent": "Variable assignment"},
    "COMPUTE": {"description": "Arithmetic operation", "aws_equivalent": "Mathematical expression"},
    "EVALUATE": {"description": "Multi-way branch (switch/case)", "aws_equivalent": "match/case (Python 3.10+), switch statement"},
    "STRING/UNSTRING": {"description": "String concatenation/splitting", "aws_equivalent": "String join/split operations"},
    "CALL": {"description": "External program invocation", "aws_equivalent": "Lambda invoke, API call, function import"},
