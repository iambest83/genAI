    "RELATIVE": {"description": "VSAM RRDS relative record", "aws_equivalent": "DynamoDB with numeric partition key", "migration_pattern": "Use auto-increment or sequence-based keys"},
    "LINE SEQUENTIAL": {"description": "Text file processing", "aws_equivalent": "S3 + Lambda line-by-line processing", "migration_pattern": "Use S3 Select or Athena for query-based access"}
  },
  "program_structure": {
    "IDENTIFICATION DIVISION": {"description": "Program metadata", "aws_equivalent": "Module/class metadata, package.json or pyproject.toml"},
