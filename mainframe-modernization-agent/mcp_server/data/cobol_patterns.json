    "DATA DIVISION": {"description": "Data structures and variables", "aws_equivalent": "Class definitions, Pydantic models, TypedDicts"},
    "PROCEDURE DIVISION": {"description": "Business logic", "aws_equivalent": "Lambda handlers, API route handlers, service classes"},
    "WORKING-STORAGE SECTION": {"description": "Program-level variables", "aws_equivalent": "Class instance variables, module-level state"},
    "LINKAGE SECTION": {"description": "Inter-program communication", "aws_equivalent": "API request/response models, SQS message schemas"},
    "COPY": {"description": "Copybook inclusion", "aws_equivalent": "Shared libraries, imported modules, API schemas"}
  },
  "common_verbs": {
