{
  "_version": "2026-05-26.1",
  "data_types": {
    "PIC 9": {"description": "Numeric field", "aws_equivalent": "Integer/Number in DynamoDB or INT in Aurora"},
    "PIC X": {"description": "Alphanumeric field", "aws_equivalent": "String in DynamoDB or VARCHAR in Aurora"},
    "PIC S9 COMP-3": {"description": "Packed decimal (signed)", "aws_equivalent": "DECIMAL in Aurora, Number in DynamoDB"},
    "PIC S9 COMP": {"description": "Binary numeric", "aws_equivalent": "BIGINT in Aurora"},
    "PIC 9V99": {"description": "Implied decimal", "aws_equivalent": "DECIMAL(x,2) in Aurora"},
    "OCCURS": {"description": "Array/table definition", "aws_equivalent": "List/Array in DynamoDB, ARRAY in Aurora PostgreSQL"},
    "REDEFINES": {"description": "Union-like overlay", "aws_equivalent": "Polymorphic JSON field or separate columns"}
  },
  "file_handling": {
    "SEQUENTIAL": {"description": "Sequential file processing (QSAM)", "aws_equivalent": "S3 objects + Lambda/Step Functions streaming", "migration_pattern": "Convert to S3 event-driven processing"},
